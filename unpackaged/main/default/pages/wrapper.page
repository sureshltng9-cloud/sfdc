<apex:page controller="WrapperCon">
    <apex:form >
        <apex:pageBlock >
            <apex:pageBlockButtons >
                <apex:commandButton value="Delete" action="{!deleteLds}"/>
            </apex:pageBlockButtons>
            <apex:pageBlockSection >
                <apex:pageBlockTable value="{!wrapLeads}" var="w">
                    <apex:column >
                        <apex:inputCheckbox value="{!w.b}"/>
                    </apex:column>
                    <apex:column value="{!w.l.FirstName}"/>
                    <apex:column value="{!w.l.LastName}"/>
                </apex:pageBlockTable>
            </apex:pageBlockSection>
        </apex:pageBlock>
    </apex:form>
</apex:page>