<!DOCTYPE html>
<html>
<head>
    <title>Custom Email Template</title>
    <style>
        /* Add styling to your table here */
        table {
            border-collapse: collapse;
            width: 80%;
            margin-left: auto;
            margin-right: auto;
        }
        th, td {
            border: 1px solid #dddddd;
            text-align: left;
            padding: 8px;
        }
        th {
            background-color: #f2f2f2;
        }
    </style>
</head>
<body>
<div style="padding-top: 30px;">
    <h2 style="text-align:center">Your Data Table</h2>
    <table>
       
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
        </tr>
        <!-- Use your own data here, this is just an example -->
        [data]
        <!-- Add more rows as needed -->
    </table>
<div>
</body>
</html>