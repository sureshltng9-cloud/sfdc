<html>

<head> </head>

<body style="margin: 0 !important; padding: 0 !important; background-color: #efefef;height: 580px;">
	<!-- container -->
	<table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" bgcolor="#efefef" style="max-width:600px">
		<!--Logo -->
		<tr>
			<td height="20px"> </td>
			<td height="10px"> </td>
		</tr>
		<!--Logo -->
		<!--copy under image -->
		<tr style="background-color: #ffffff;">
			<td>
				<table width="100%" border="0" cellspacing="0" cellpadding="0">
					<tr>
						<td height="20px"> </td>
					</tr>
					<tr style="background-color:#ffffff;">
						<td align="center">
							<table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color: #ffffff;">
								<tr>
									<td align="center" valign="top" style="padding-top: 20px;padding-bottom:20px;text-align: center;padding: 0 0 0 16px;" class="logo">
										<a href="" target="_blank"> <img alt="Logo" src=[logoURL] height="128px" style=" text-align: left;padding: 0px 0px 0px 16px;  width: auto !important;   height: 65px !important;" border="0" /> </a>
									</td>
								</tr>
							</table>
						</td>
					</tr>
					<tr>
						<td height="10px"> </td>
					</tr>
					<tr style="background-color: #ffffff">
						<td align="center">
							<!-- SECTION COPY -->
							<table align="center" border="0" cellspacing="0" cellpadding="0" style="max-width:500px;">
								<br/>
								<tbody>
									<tr style="border:0 none;border-collapse:separate">
										<div style="background-color:#1aa3ff;height:45px;width: 100%">
											<p style="color:white;font-size:20px;text-align:center;padding-top: 10px;">Event Enrollment Confirmation</p>
										</div>
									</tr>
									<tr style="border:0 none;border-collapse:separate">
										<td style="font-size: 14px; font-family: 'Heebo', sans-serif; color: #00386e;padding-top:10px;padding-bottom:20px;" valign="middle">Dear <b>[parent]</b>, </td>
									</tr>
									<tr style="border:0 none;border-collapse:separate">
										<td style="font-size: 14px; font-family: 'Heebo', sans-serif; color: #00386e;padding-top:10px;padding-bottom:10px;" valign="middle">your childern have been Enrolled to <b>[Program] </b> Successfully</td>
									</tr>
									<tr style="border:0 none;border-collapse:separate">
										<td style="font-size: 14px; font-family: 'Heebo', sans-serif; color: #00386e;padding-top:10px;padding-bottom:10px;" align="center">
											<div style="width: 300px; background-color: #e0ebeb;border: 1px solid #3d5c5c; padding: 30px;margin: 20px;margin: auto">
												<p><b>[students</b>]</p>
												<p>Date : [dt]</p>
												<p>Time : [tm]</p>
											</div>
										</td>
									</tr>
								</tbody>
								<tr>
									<td height="30px"> </td>
								</tr>
							</table>
						</td>
					</tr>
				</table>
			</td>
		</tr>
	</table>
</body>

</html>